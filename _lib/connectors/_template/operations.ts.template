// ─── High-level recipes (= typické dashboard queries) ────────────────────

/**
 * Recept: Tržby za období.
 */
export async function getRevenueForPeriod(
  creds: Credentials,
  dateRange: { from: string; to: string },
): Promise<{ total: number; currency: string; count: number }> {
  const invoices = await getInvoices(creds, dateRange);
  // ↓ Adaptuj podle pole, které drží částku
  const paid = invoices; // .filter(i => i.paid) — pokud existuje pole
  const total = paid.reduce((sum, inv) => sum + (Number((inv as any).total) || 0), 0);
  return { total, currency: 'CZK', count: paid.length };
}

